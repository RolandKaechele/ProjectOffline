# ── Default: auto-detect text vs binary, normalise line endings to LF in repo
* text=auto eol=lf

# ── Python ───────────────────────────────────────────────────────────────────
*.py    text eol=lf diff=python
*.pyi   text eol=lf diff=python
*.pyc   binary -filter -diff -merge
*.pyd   binary -filter -diff -merge

# ── Markup / config ───────────────────────────────────────────────────────────
*.md    text eol=lf
*.rst   text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf

# ── PlantUML / XML ────────────────────────────────────────────────────────────
*.puml  text eol=lf
*.plantuml text eol=lf
*.xml   text eol=lf

# ── Windows scripts — must stay CRLF on checkout ─────────────────────────────
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

