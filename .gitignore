# ── SVN ────────────────────────────────────────────────────────────────────
*.svn*/

# ── Virtual environment (svn:ignore on root: venv) ─────────────────────────
venv/

# ── Temporary files (svn:ignore on root: temp) ──────────────────────────────
temp/
debug_*.json

# ── User-specific config files (machine-local, not for version control) ──────
email_configs.json

# ── Microsoft Project files ───────────────────────────────────────────────────
*.mpp
*.mpx

# ── Binary files ─────────────────────────────────────────────────────────────
*.7z
*._br
*._cn
*._de
*._es
*._fr
*._hu
*._it
*._jp
*.a
*.accdb
*.bin
*.bz2
*.chm
*.class
*.cp_
*.deb
*.dblite
*.dl_
*.dll
*.doc
*.docx
*.dot
*.dotx
*.eap
*.EAP
*.eap_bak
*.elf
*.ex_
*.exe
*.gif
*.gm
*.ico
*.jar
*.jpg
*.jsa
*.jsa
*.lib
*.lnk
*.lzma
*.ncb
*.pch
*.pdf
*.pf
*.png
*.PNG
*.potx
*.ppt
*.pptx
*.pscp
*.pyc
*.pyd
*.rpm
*.sdf
