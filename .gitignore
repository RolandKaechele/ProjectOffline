*.zip
*.zipx

# ── Bundled JDK (svn:ignore on tools: java) ─────────────────────────────────
tools/java/
tools/plantuml*/
tools/extensions/
tools/git/
tools/innosetup/
tools/requirementProcessTool_*/
tools/svn/

# ── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]

# ── Pytest cache (svn:global-ignores: .pytest_cache) ────────────────────────
.pytest_cache/

# ── Coverage ─────────────────────────────────────────────────────────────────
.coverage

# ── Build / distribution ─────────────────────────────────────────────────────
build/
dist/
*.egg-info/

# ── Generated Inno Setup script (produced by SConstruct from installer/setup.iss.template) ──
setup.iss

# ── Debug / log artefacts ────────────────────────────────────────────────────
*.log
debug_output.txt

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
