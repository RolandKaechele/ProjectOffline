      <GROUP_OBJECTS>
        <OBJECTS ID.Status="1_Heading.0" Object_Heading="1 Confluence Calendar Sync" Object_Text="" Section_number="1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="1.0" Object_Heading="" Object_Text="Requirements for importing public holidays and team vacations from a Confluence Team Calendar via Playwright SSO." Section_number="1.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="1_1_Heading.0" Object_Heading="1.1 Confluence Sync Requirements" Object_Text="" Section_number="1.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="2.0" Object_Heading="" Object_Text="The system shall import public holiday and vacation blocks from a Confluence Team Calendar into the project and resource calendars." Section_number="1.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="3.0" Object_Heading="" Object_Text="The sync shall authenticate with Confluence via Playwright-driven SSO without requiring manual credential entry during sync." Section_number="1.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="4.0" Object_Heading="" Object_Text="The sync shall automatically create project resources for Confluence calendar members who do not yet exist in the resource sheet." Section_number="1.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5.0" Object_Heading="" Object_Text="The sync shall remove stale calendar entries that were cancelled in Confluence on every sync run." Section_number="1.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="6.0" Object_Heading="" Object_Text="The sync shall prune calendar exceptions older than 30 days from all resource calendars." Section_number="1.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7.0" Object_Heading="" Object_Text="The entire Confluence Calendar Sync operation shall be fully undoable with a single Ctrl+Z." Section_number="1.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="8.0" Object_Heading="" Object_Text="The system shall provide a Confluence Calendar Config dialog allowing the user to configure: Confluence Base URL, Space Key, Timezone (IANA zone, editable QComboBox with all 598 zones, default Europe/Berlin), and Days Ahead." Section_number="1.1.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9.0" Object_Heading="" Object_Text="The Confluence Calendar Config dialog shall include a KeePass/Auth section offering a choice between Manual SSO and KeePass entry auto-fill." Section_number="1.1.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10.0" Object_Heading="" Object_Text="Confluence calendar configuration (Base URL, Space Key, Timezone, Days Ahead) shall be stored as enterprise custom fields on the project summary task (UID=0)." Section_number="1.1.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="11.0" Object_Heading="" Object_Text="The ribbon shall include a Confluence Calendar Config button (always enabled) and a Confluence Sync button (enabled when a project is open)." Section_number="1.1.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="12.0" Object_Heading="" Object_Text="The Confluence calendar enterprise custom fields shall include at minimum: CALENDAR Base URL, CALENDAR Space Key, CALENDAR Timezone, and CALENDAR Days Ahead." Section_number="1.1.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="13.0" Object_Heading="" Object_Text="When writing public-holiday events from Confluence to the project default calendar, the system shall skip any event whose end date differs from its start date (event duration &gt; 0 days). Only events where start == end (single calendar day) shall be written as calendar exceptions. Multi-day spans such as school-holiday blocks (&quot;Schulferien&quot;) and collective closures shall not be applied to the project default calendar; writing them would grey out entire weeks for all resources in the Team Planner." Section_number="1.1.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="2_Heading.0" Object_Heading="2 Secondary Calendar Integration" Object_Text="" Section_number="2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="14.0" Object_Heading="" Object_Text="Requirements for managing per-resource secondary regional holiday calendars, persisted in the project file and surfaced in the Team Planner." Section_number="2.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="2_1_Heading.0" Object_Heading="2.1 Secondary Calendar Integration Requirements" Object_Text="" Section_number="2.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="15.0" Object_Heading="" Object_Text="The system shall provide a secondary_calendar_integration module that stores and retrieves per-resource secondary calendar assignments as a JSON map in the MPXJ project custom properties under the key &quot;AD Secondary Calendars&quot;." Section_number="2.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="16.0" Object_Heading="" Object_Text="The secondary calendar map shall use resource unique ID strings as keys and store at minimum the calendar_name, calendar_uid (nullable), and source (e.g. &quot;ad:auto-match&quot; or &quot;manual&quot;) for each assigned resource." Section_number="2.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="17.0" Object_Heading="" Object_Text="The module shall expose a get_secondary_calendar_map(project) function returning the full {uid → entry} dict, a set_secondary_calendar_for_resource(...) function for creating and clearing entries, and a resolve_secondary_calendar(project, resource) function that looks up the mapped MPXJ calendar object (by UID first, then by name)." Section_number="2.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="18.0" Object_Heading="" Object_Text="resolve_secondary_calendar shall return None when no mapping exists for the resource; it shall return a result dict with calendar=None when a mapping exists but the named calendar is not found in the project calendar list, so that callers can distinguish &quot;not configured&quot; from &quot;calendar not yet imported&quot;." Section_number="2.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="19.0" Object_Heading="" Object_Text="The module shall expose an assign_secondary_calendar_from_ad(project, resource, ad_user) function that infers the best-matching project calendar from the AD user's location fields and persists the assignment; it shall return None and make no change when no matching calendar is found." Section_number="2.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="3_Heading.0" Object_Heading="3 KeePass Integration" Object_Text="" Section_number="3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="20.0" Object_Heading="" Object_Text="Requirements for connecting to a local KeePass 4.x database to retrieve credentials used by integrations." Section_number="3.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="3_1_Heading.0" Object_Heading="3.1 KeePass Requirements" Object_Text="" Section_number="3.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="21.0" Object_Heading="" Object_Text="The system shall connect to a local KeePass 4.x KDBX database file using the pykeepass library." Section_number="3.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="22.0" Object_Heading="" Object_Text="The KeePass integration shall support unlocking the database via master password and/or key file." Section_number="3.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="23.0" Object_Heading="" Object_Text="The system shall support retrieving credentials from the KeePass database by entry name or entry path." Section_number="3.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="24.0" Object_Heading="" Object_Text="The KeePass database shall be automatically locked after a configurable idle timeout." Section_number="3.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="25.0" Object_Heading="" Object_Text="The KeePass database file path shall be saved in QSettings via the SettingsManager and selectable from the KeePass Configuration dialog." Section_number="3.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="26.0" Object_Heading="" Object_Text="Sensitive information (master password, key file content) shall never be written to log files, debug dumps, or settings files." Section_number="3.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="4_Heading.0" Object_Heading="4 Enterprise Custom Fields" Object_Text="" Section_number="4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="4_1_Heading.0" Object_Heading="4.1 Custom Field Requirements" Object_Text="" Section_number="4.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="27.0" Object_Heading="" Object_Text="The system shall store per-project configuration as MPXJ enterprise custom fields on the project summary task (UID=0)." Section_number="4.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="28.0" Object_Heading="" Object_Text="Enterprise custom field data shall be preserved when the project file is saved and loaded, making it portable across teams." Section_number="4.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_Heading.0" Object_Heading="5 Active Directory Integration" Object_Text="" Section_number="5" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="29.0" Object_Heading="" Object_Text="Requirements for querying corporate Active Directory to populate and synchronise the project resource sheet via PowerShell Get-ADUser (RSAT)." Section_number="5.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_1_Heading.0" Object_Heading="5.1 AD Integration Requirements" Object_Text="" Section_number="5.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="30.0" Object_Heading="" Object_Text="The system shall query Active Directory via PowerShell Get-ADUser to look up user details (display name, email, department, SAM account name) without requiring a third-party LDAP library." Section_number="5.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="31.0" Object_Heading="" Object_Text="The AD integration shall support looking up a user by display name using two strategies in order: (1) DisplayName exact match, (2) Surname and GivenName split on &quot;, &quot;." Section_number="5.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="32.0" Object_Heading="" Object_Text="The AD integration shall support looking up a user by email address (mail attribute)." Section_number="5.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="33.0" Object_Heading="" Object_Text="The AD integration shall support looking up a user by SAM account name using the Get-ADUser -Identity parameter." Section_number="5.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="34.0" Object_Heading="" Object_Text="The AD integration module shall expose an is_ad_available() function that checks whether PowerShell and the ActiveDirectory RSAT module are accessible, and returns a boolean result." Section_number="5.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="35.0" Object_Heading="" Object_Text="All AD lookup functions shall sanitise input strings to reject characters that could be used for PowerShell filter injection (parentheses, wildcard, backslash, null byte, and shell metacharacters)." Section_number="5.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="36.0" Object_Heading="" Object_Text="Each PowerShell subprocess invocation shall be subject to a configurable timeout (default 60 s) stored via QSettings under the ad/timeout_seconds key; the default was increased from 10 s to 60 s because wildcard AD scans (mail -like, SamAccountName -like) must load the AD module on first call and can take 20–30 s on large corporate directories." Section_number="5.1.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="37.0" Object_Heading="" Object_Text="Each lookup function (lookup_by_name, lookup_by_email, lookup_by_username) shall return a normalised dict with keys display_name, email, department, and username when a matching AD entry with a valid mail attribute is found, or None when no match is found." Section_number="5.1.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="38.0" Object_Heading="" Object_Text="lookup_by_name shall try strategy 1 (DisplayName exact match) and, when unsuccessful, strategy 2 (Surname and GivenName split on &quot;, &quot;); it shall record every call — whether a result was found or not — in the lookup history ring-buffer before returning." Section_number="5.1.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="39.0" Object_Heading="" Object_Text="lookup_by_email shall query AD by mail attribute and record every call in the lookup history ring-buffer before returning." Section_number="5.1.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="40.0" Object_Heading="" Object_Text="lookup_by_username shall query AD using Get-ADUser -Identity (SAM account name) and record every call in the lookup history ring-buffer before returning." Section_number="5.1.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="41.0" Object_Heading="" Object_Text="The lookup history list shall be unbounded and accumulate all lookup calls for the lifetime of the current process session." Section_number="5.1.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="42.0" Object_Heading="" Object_Text="The module shall expose a get_last_lookup_results() function that returns a shallow copy of the full lookup history list as a list of {fn, input, result} dicts." Section_number="5.1.13" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="43.0" Object_Heading="" Object_Text="The AD integration module shall expose multi-result lookup functions (lookup_by_name_all, lookup_by_email_all, lookup_by_username_all) that return all matching AD users as a list of normalised dicts, using case-insensitive wildcard filters without a -First 1 limit." Section_number="5.1.14" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="44.0" Object_Heading="" Object_Text="Each multi-result lookup function shall sanitise input strings using the same injection-rejection rules as the single-result functions, and record the call in the lookup history list before returning." Section_number="5.1.15" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="45.0" Object_Heading="" Object_Text="The AD integration module shall expose a get_thumbnail(username) function that retrieves the thumbnailPhoto binary attribute from AD for the given SAM account name and returns the raw JPEG/PNG bytes, or None when the attribute is absent or the request fails." Section_number="5.1.16" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="46.0" Object_Heading="" Object_Text="The resource sheet context menu shall include an &quot;Add from Active Directory…&quot; action that opens the ADSearchDialog to search for and add a user as a resource." Section_number="5.1.17" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="47.0" Object_Heading="" Object_Text="The ADSearchDialog shall accept search input for username (SAM account name), display name, and e-mail address; pressing Enter or clicking Search shall trigger the query against Active Directory." Section_number="5.1.18" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="48.0" Object_Heading="" Object_Text="When a single AD user matches the search criteria, the ADSearchDialog shall show that user's formatted name, e-mail, and department in a confirmation card and enable the &quot;Add Resource&quot; button." Section_number="5.1.19" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="49.0" Object_Heading="" Object_Text="When multiple AD users match the search criteria, the system shall open the ADUserSelectDialog displaying one clickable card per user with initials, formatted name, e-mail, department, and username; the user clicks a card to select one." Section_number="5.1.20" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="50.0" Object_Heading="" Object_Text="After a user is selected in the ADSearchDialog, the dialog shall attempt to load the AD thumbnailPhoto for the selected user and display it as a circular avatar; if no photo is available the avatar shall show the user's initials on a blue background." Section_number="5.1.21" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="51.0" Object_Heading="" Object_Text="The new resource name shall be set to the format &quot;Nachname, Vorname&quot; derived from the AD DisplayName; if DisplayName already contains &quot;, &quot; it is used unchanged, otherwise the last space-separated token is treated as the surname." Section_number="5.1.22" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="52.0" Object_Heading="" Object_Text="After accepting the ADSearchDialog, the Resource Information dialog shall open pre-filled with the formatted name and e-mail; the user can review and adjust before confirming." Section_number="5.1.23" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="53.0" Object_Heading="" Object_Text="Adding a resource via the AD search dialog shall be fully undoable and redoable via the existing history manager snapshot mechanism (data_changed signal triggers push('resources'))." Section_number="5.1.24" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="54.0" Object_Heading="" Object_Text="When a resource is added via the AD search dialog, the system shall automatically create a personal calendar for the new resource derived from the project default calendar (setParent()); if no default calendar exists, the standard Mon–Fri working-week shall be configured directly on the new calendar." Section_number="5.1.25" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="55.0" Object_Heading="" Object_Text="The personal resource calendar shall be named &quot;&lt;Resource Name&gt; Calendar&quot; and assigned a unique calendar UID before being linked to the resource via setCalendar()." Section_number="5.1.26" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="56.0" Object_Heading="" Object_Text="The RESOURCE ribbon panel Insert group shall contain an &quot;Add from AD&quot; button that opens the AD search dialog and adds the chosen user as a new resource; the button shall be disabled whenever no project is open (same _project_btns gating as the existing &quot;Add Resource&quot; button)." Section_number="5.1.27" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="57.0" Object_Heading="" Object_Text="The AD integration shall fully support Unicode display names, email addresses, and department strings including umlauts (ä, ü, ö, Ä, Ü, Ö, ß) and other non-ASCII characters; PowerShell stdout shall be decoded as UTF-8 ([Console]::OutputEncoding and $OutputEncoding set to UTF8 before each subprocess invocation, stdout read as raw bytes and decoded with utf-8/replace)." Section_number="5.1.28" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="58.0" Object_Heading="" Object_Text="The personal resource calendar created for an AD resource shall copy only the per-day-of-week working/non-working type settings from the project default calendar (via setCalendarDayType per DayOfWeek) and shall NOT inherit or copy calendar exceptions (public holidays, project closures) from the default calendar; the resource calendar starts clean so that individual exceptions can be managed independently." Section_number="5.1.29" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="59.0" Object_Heading="" Object_Text="lookup_by_email_all and lookup_by_username_all shall attempt an exact indexed match first (mail -eq for email, Get-ADUser -Identity for username) before falling back to a wildcard scan (mail -like, SamAccountName -like); when the exact match succeeds the wildcard scan shall not be executed, reducing typical lookup time from 20–30 s to under 1 s." Section_number="5.1.30" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="60.0" Object_Heading="" Object_Text="The AD integration module shall include the city (l), state/province (st), and country (co) LDAP attributes in every user lookup result dict under the keys &quot;city&quot;, &quot;state&quot;, and &quot;country&quot;; these fields shall be included in the PowerShell Get-ADUser -Properties list and normalised to empty string when absent." Section_number="5.1.31" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_2_Heading.0" Object_Heading="5.2 Secondary Calendar Inference from AD" Object_Text="" Section_number="5.2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="61.0" Object_Heading="" Object_Text="When a resource is added via the AD search dialog, the system shall automatically infer a secondary holiday calendar for the resource by scoring installed project calendars against the AD user's location fields (city, state, country) and assigning the highest-scoring calendar when a match is found." Section_number="5.2.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="62.0" Object_Heading="" Object_Text="The secondary calendar inference shall prefer calendars with a higher number of non-working exceptions (up to a bonus of 5 score points) so that calendars actively populated with holidays rank above empty placeholder calendars of the same name." Section_number="5.2.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="63.0" Object_Heading="" Object_Text="The secondary calendar inference shall skip personal resource calendars (those whose name ends in &quot; Calendar&quot; with two or fewer name tokens) to avoid confusing a resource's own working calendar with a regional holiday calendar." Section_number="5.2.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_3_Heading.0" Object_Heading="5.3 AD Group Integration" Object_Text="" Section_number="5.3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="64.0" Object_Heading="" Object_Text="Requirements for searching Active Directory groups and bulk-adding their enabled members to the project resource sheet." Section_number="5.3.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_3_1_Heading.0" Object_Heading="5.3.1 AD Group Search Function" Object_Text="" Section_number="5.3.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="65.0" Object_Heading="" Object_Text="The AD integration module shall expose a search_groups(query) function that searches Active Directory for groups whose Name attribute contains the query string (case-insensitive wildcard, e.g. Get-ADGroup -Filter &quot;Name -like '*query*'&quot;) and returns a list of group dicts, each containing: name, description, dn (DistinguishedName), category, scope, and sam_name." Section_number="5.3.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="66.0" Object_Heading="" Object_Text="search_groups shall sanitise the query string to reject the same injection characters as the single-result lookup functions (parentheses, backslash, null byte, shell metacharacters); an empty or whitespace-only query shall return an empty list without invoking PowerShell." Section_number="5.3.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="67.0" Object_Heading="" Object_Text="When PowerShell returns a single JSON object for a one-group result, search_groups shall automatically wrap it in a list so the caller always receives a list." Section_number="5.3.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="68.0" Object_Heading="" Object_Text="search_groups shall silently skip any group entry that has neither a Name nor a SamAccountName, and shall return an empty list when PowerShell returns None or non-JSON output." Section_number="5.3.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_3_2_Heading.0" Object_Heading="5.3.2 AD Group Members Function" Object_Text="" Section_number="5.3.2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="69.0" Object_Heading="" Object_Text="The AD integration module shall expose a get_group_members(group_name_or_dn) function that retrieves all enabled user members of an AD group using Get-ADGroupMember -Recursive, filters to objectClass == 'user' and Enabled == True, and returns a list of normalised user dicts (same schema as single-result lookups: display_name, email, department, username, city, state, country)." Section_number="5.3.2.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="70.0" Object_Heading="" Object_Text="get_group_members shall sanitise the input string to reject injection characters; an empty or whitespace-only input shall return an empty list without invoking PowerShell." Section_number="5.3.2.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="71.0" Object_Heading="" Object_Text="get_group_members shall exclude any member entry whose mail attribute is absent (None) or does not contain an @ character, matching the email validity rule applied by other lookup functions." Section_number="5.3.2.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="72.0" Object_Heading="" Object_Text="get_group_members shall return an empty list when PowerShell returns None or non-JSON output, and shall wrap a single-user JSON object in a list so the caller always receives a list." Section_number="5.3.2.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_3_3_Heading.0" Object_Heading="5.3.3 AD Group Search Dialog" Object_Text="" Section_number="5.3.3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="73.0" Object_Heading="" Object_Text="The system shall provide an ADGroupSearchDialog that allows the user to search AD groups by name, browse the resulting group cards, expand a group card to preview its member list, and select members to add to the project resource sheet." Section_number="5.3.3.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="74.0" Object_Heading="" Object_Text="The ADGroupSearchDialog shall expose a get_selected_users() method that returns the list of user dicts for all members the user has chosen to add." Section_number="5.3.3.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_3_4_Heading.0" Object_Heading="5.3.4 Bulk Add Resources from AD Group" Object_Text="" Section_number="5.3.4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="75.0" Object_Heading="" Object_Text="The resource sheet shall provide an add_resources_from_ad_group() action that opens the ADGroupSearchDialog, iterates the selected users, skips any user whose formatted name (case-insensitive) already exists as a project resource, creates a new resource with a unique ID and personal calendar for each remaining user, and shows a summary QMessageBox stating how many resources were added and how many were skipped." Section_number="5.3.4.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="76.0" Object_Heading="" Object_Text="The resource sheet context menu shall include an &quot;Add from AD Group…&quot; action that triggers add_resources_from_ad_group()." Section_number="5.3.4.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="77.0" Object_Heading="" Object_Text="The RESOURCE ribbon panel Insert group shall contain an &quot;Add from AD Group&quot; button that triggers add_resources_from_ad_group(); the button shall be disabled whenever no project is open." Section_number="5.3.4.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="5_4_Heading.0" Object_Heading="5.4 Manual AD Lookup from Resource Information Dialog" Object_Text="" Section_number="5.4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="78.0" Object_Heading="" Object_Text="When Active Directory is available on the current machine, the Resource Information dialog shall display a &quot;Look up in AD…&quot; button placed inline next to the E-Mail field; if the resource name field is blank when the button is activated, the system shall display an information dialog prompting the user to enter a resource name before searching." Section_number="5.4.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="79.0" Object_Heading="" Object_Text="Activating the &quot;Look up in AD…&quot; button shall search Active Directory by the resource's current display name using lookup_by_name_all(); when exactly one match is found, the E-Mail and Department fields shall be pre-filled with the matched user's email and department attributes; the user may still edit the fields before accepting the dialog." Section_number="5.4.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="80.0" Object_Heading="" Object_Text="When multiple AD entries match the resource display name, the system shall present the ADUserSelectDialog so the user can choose one candidate; the chosen entry's attributes shall then be used to pre-fill the E-Mail and Department fields." Section_number="5.4.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="81.0" Object_Heading="" Object_Text="When no AD entry matches the resource display name, the system shall display an information dialog indicating that no match was found; the E-Mail and Department fields shall remain unchanged." Section_number="5.4.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="6_Heading.0" Object_Heading="6 Email Integration" Object_Text="" Section_number="6" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="82.0" Object_Heading="" Object_Text="Requirements for sending project exports (SVG Gantt charts, Team Planner snapshots, resource utilisation graphs) as email attachments via SMTP with KeePass credential management." Section_number="6.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="6_1_Heading.0" Object_Heading="6.1 Email Integration Requirements" Object_Text="" Section_number="6.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="83.0" Object_Heading="" Object_Text="The system shall send emails via SMTP with authentication using credentials retrieved from a KeePass database entry." Section_number="6.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="84.0" Object_Heading="" Object_Text="The email integration shall support SMTP with STARTTLS on a configurable port (default 587), falling back to unencrypted SMTP when TLS is not available." Section_number="6.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="85.0" Object_Heading="" Object_Text="The email integration shall store configuration settings (SMTP server, SMTP port, use TLS flag, sender address, KeePass entry name) via the SettingsManager under the email/ prefix in QSettings." Section_number="6.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="86.0" Object_Heading="" Object_Text="The email integration shall expose an is_configured() function that returns True when server, sender address, and KeePass entry name are all set, and False otherwise." Section_number="6.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="87.0" Object_Heading="" Object_Text="The email integration shall expose a test_connection() function that connects to the SMTP server, authenticates with the KeePass credentials, and returns a tuple (success: bool, error_message: str)." Section_number="6.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="88.0" Object_Heading="" Object_Text="The email integration shall expose a send_email(to, subject, body, attachments) function that supports single or multiple recipients, plain text body, and optional file attachments as a list of (filename, bytes) tuples." Section_number="6.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="89.0" Object_Heading="" Object_Text="The system shall provide an Email Configuration dialog accessible from a button in the Report ribbon panel (always enabled, as email settings are global and not project-gated)." Section_number="6.1.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="90.0" Object_Heading="" Object_Text="The Email Configuration dialog shall display the KeePass database lock state with three states: not configured, locked, and unlocked (with entry list populated)." Section_number="6.1.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="91.0" Object_Heading="" Object_Text="The Email Configuration dialog shall include a Test Connection button that saves current settings, calls email_integration.test_connection(), and displays the result in a QMessageBox." Section_number="6.1.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="92.0" Object_Heading="" Object_Text="The Email Configuration dialog shall include a Send Test Email button that opens a wider dialog (400 px) prompting for a recipient email address, with a Use My Email button that auto-fills the recipient by looking up the current KeePass entry username in Active Directory." Section_number="6.1.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="93.0" Object_Heading="" Object_Text="The Email Configuration dialog (EmailConfigDialog) shall include a &quot;From KeePass…&quot; button in the Sender (Per-Project) section that auto-fills the sender email address by looking up the current KeePass entry username in Active Directory; the button shall be absent from the EmailServerEditDialog." Section_number="6.1.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="94.0" Object_Heading="" Object_Text="The email integration shall use a configurable SMTP connection timeout of 30 seconds." Section_number="6.1.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="95.0" Object_Heading="" Object_Text="The email integration shall track the last send result (timestamp, success, recipient count, error message) and last test result (timestamp, success, error message) in module-level variables for diagnostic purposes." Section_number="6.1.13" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="96.0" Object_Heading="" Object_Text="The email integration shall expose a get_config_summary() function that returns a dict with configured, smtp_server, smtp_port, smtp_use_tls, sender_address, keepass_entry_set (bool), last_send, and last_test keys, without exposing any passwords or sensitive credentials." Section_number="6.1.14" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="97.0" Object_Heading="" Object_Text="Sensitive information (SMTP passwords, KeePass credentials) shall never be written to log files, debug dumps, QSettings, or displayed in error messages." Section_number="6.1.15" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="98.0" Object_Heading="" Object_Text="All email integration error messages shall be user-friendly and shall not contain technical jargon, stack traces, or exception class names." Section_number="6.1.16" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="99.0" Object_Heading="" Object_Text="When no SMTP email accounts are configured (SettingsManager.get_email_configs() returns an empty list) or no active account name matches any configured account, the email export actions in the Report ribbon split-button popups — Email Gantt SVG, Email to All Resources, and Email Timeline SVG — shall be rendered as disabled (greyed-out, non-interactive); each disabled item shall show a tooltip explaining how to add an SMTP account and select it via Email Config. The enabled/disabled state shall be re-evaluated at application startup and whenever the Email Accounts dialog (EmailServersDialog) or the Email Config dialog (EmailConfigDialog) is closed." Section_number="6.1.17" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="6_2_Heading.0" Object_Heading="6.2 Email Multiple Account Requirements" Object_Text="" Section_number="6.2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="100.0" Object_Heading="" Object_Text="The system shall support storing multiple named SMTP email account configurations (name, smtp_server, smtp_port, smtp_use_tls) as a JSON array in a plain file (email_configs.json) next to the executable; sender_address and the KeePass credential entry are NOT stored per account and are NOT included in this file." Section_number="6.2.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="101.0" Object_Heading="" Object_Text="The system shall designate one email configuration as the active account, stored by name in the email_configs.json file under the active_config_name key." Section_number="6.2.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="102.0" Object_Heading="" Object_Text="On first access, if the email/configs list is empty but the legacy single-config key email/smtp_server is set, the system shall automatically migrate the existing settings into a config entry named &quot;Default&quot; and store it in the email/configs list." Section_number="6.2.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="103.0" Object_Heading="" Object_Text="The system shall provide an Email Accounts dialog (EmailServersDialog) accessible from an always-enabled &quot;Email Accounts&quot; button in the Report ribbon panel that lists all configured SMTP accounts and supports Add, Edit, Delete, Set Active, Move Up, and Move Down operations." Section_number="6.2.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="104.0" Object_Heading="" Object_Text="The Email Accounts list shall display each account as &quot;name ★ — server&quot;, with a ★ suffix appended to the active account name." Section_number="6.2.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="105.0" Object_Heading="" Object_Text="The system shall provide an Email Account Edit dialog (EmailServerEditDialog) for adding or editing a single SMTP configuration, containing fields for Name, SMTP Server, SMTP Port, and Use TLS checkbox only; the dialog shall NOT contain a Sender Address field, a KeePass section, or a &quot;From KeePass…&quot; button — sender address is stored per-project in enterprise custom properties, not per account." Section_number="6.2.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="106.0" Object_Heading="" Object_Text="The Email Account Edit dialog (EmailServerEditDialog) shall NOT include a Test Connection button; the dialog is limited to SMTP server configuration fields only." Section_number="6.2.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="107.0" Object_Heading="" Object_Text="All email_integration module functions (is_configured, send_email, test_connection) shall accept an optional config dict parameter; when provided, the explicit config is used in place of the active account." Section_number="6.2.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="108.0" Object_Heading="" Object_Text="When no explicit config is provided, email functions shall resolve the active config via SettingsManager.get_active_email_config(); when that returns no valid dict (e.g. empty list), functions shall fall back to the legacy single-config QSettings keys for backward compatibility." Section_number="6.2.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="109.0" Object_Heading="" Object_Text="The get_config_summary() function shall include multi-config keys num_configs (int), active_config_name (str), active_configured (bool), and configs (list of dicts with keepass_entry_set bool instead of the raw entry name) alongside the existing legacy keys." Section_number="6.2.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="110.0" Object_Heading="" Object_Text="The KeePass credential entry for email authentication shall be stored globally under the email/keepass_entry QSettings key and shall be shared by all SMTP accounts; it shall be configurable only via the Email Configuration dialog (EmailConfigDialog), not per individual account." Section_number="6.2.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="111.0" Object_Heading="" Object_Text="The _get_keepass_entry(config) function shall resolve the KeePass entry using a two-step fallback: first, if the config dict contains a non-empty keepass_entry key (present in legacy-migrated &quot;Default&quot; entries for backward compatibility), that value is returned; otherwise, the global email/keepass_entry value from SettingsManager is returned." Section_number="6.2.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="112.0" Object_Heading="" Object_Text="The is_configured(config) function shall return True only when smtp_server, sender_address, and the resolved KeePass entry (via the two-step fallback in _get_keepass_entry) are all non-empty; a config dict without a keepass_entry key shall be considered fully configured when the global email/keepass_entry is set." Section_number="6.2.13" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="6_3_Heading.0" Object_Heading="6.3 Email Config JSON File Storage Requirements" Object_Text="" Section_number="6.3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="113.0" Object_Heading="" Object_Text="The system shall store the email account list (configs array) and active account name in a plain JSON file named email_configs.json; the file format shall be { &quot;active_config_name&quot;: str, &quot;configs&quot;: [ ... ] } with UTF-8 encoding and human-readable 2-space indentation." Section_number="6.3.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="114.0" Object_Heading="" Object_Text="When running as a bundled PyInstaller executable (sys.frozen is True), email_configs.json shall be placed in the same directory as the executable so that the entire installation folder can be copied between machines to transfer the configuration." Section_number="6.3.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="115.0" Object_Heading="" Object_Text="When running in development mode (sys.frozen is absent or False), email_configs.json shall be placed at the project root directory (one level above src/)." Section_number="6.3.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="116.0" Object_Heading="" Object_Text="On the first call to SettingsManager.get_email_configs() when email_configs.json is absent or empty, the system shall migrate existing data from QSettings in priority order: (1) new-style email/configs JSON string, (2) legacy single-config keys (email/smtp_server, etc.); after migration the data shall be written to email_configs.json so subsequent calls read from the file only." Section_number="6.3.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="117.0" Object_Heading="" Object_Text="Legacy single-config migration shall produce a config entry named &quot;Default&quot; containing only smtp_server, smtp_port, and smtp_use_tls; the keepass_entry QSettings value and sender_address shall NOT be copied into the per-account dict, since sender_address is now stored per-project." Section_number="6.3.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="118.0" Object_Heading="" Object_Text="The KeePass credential entry name (email/keepass_entry) shall remain in QSettings and shall NOT be written to email_configs.json, since it references a machine-local KeePass database path and is not portable." Section_number="6.3.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="119.0" Object_Heading="" Object_Text="Reading email_configs.json shall be fault-tolerant: a missing file, invalid JSON, or OS error shall return an empty dict without raising an exception, causing the caller to fall back to migration or return an empty list." Section_number="6.3.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="120.0" Object_Heading="" Object_Text="The email_configs.json file shall be excluded from version control (listed in .gitignore) because it contains machine-specific server hostnames and sender addresses." Section_number="6.3.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="6_4_Heading.0" Object_Heading="6.4 Email Account Selection and Per-Project Sender Name" Object_Text="" Section_number="6.4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="121.0" Object_Heading="" Object_Text="The redesigned EmailConfigDialog shall provide an account-selection section containing: a QComboBox listing all configured SMTP accounts by name (one item per account), a &quot;Manage Accounts…&quot; button, and a warning label informing the user that no SMTP accounts are configured; the combo shall be shown and the label hidden when the account list is non-empty, and the label shall be shown and the combo hidden when the list is empty." Section_number="6.4.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="122.0" Object_Heading="" Object_Text="The EmailConfigDialog &quot;Manage Accounts…&quot; button shall open the EmailServersDialog; after that dialog closes the account QComboBox shall be reloaded from SettingsManager.get_email_configs() and the previously selected account name re-selected when still present in the refreshed list." Section_number="6.4.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="123.0" Object_Heading="" Object_Text="The EmailConfigDialog shall include a per-project Sender Name QLineEdit for the display name used in the From: header of outgoing emails (e.g. &quot;Alice Smith&quot;); this field is separate from the Sender Address (smtp-level From address) that is also stored per-project in enterprise custom properties, not per SMTP account." Section_number="6.4.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="124.0" Object_Heading="" Object_Text="On accepting the EmailConfigDialog, the selected SMTP account name shall be written to the project sidecar JSON under the MPXJ enterprise custom property key &quot;Email Active Account&quot; using a java.util.HashMap passed to project.getProjectProperties().setCustomProperties(), using the same persistence mechanism as JiraSyncConfigDialog." Section_number="6.4.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="125.0" Object_Heading="" Object_Text="On accepting the EmailConfigDialog, the sender display name shall be written to the project sidecar JSON under the MPXJ enterprise custom property key &quot;Email Sender Name&quot; using the same HashMap mechanism." Section_number="6.4.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="126.0" Object_Heading="" Object_Text="When EmailConfigDialog is initialised with a project argument, it shall load the active account name from the &quot;Email Active Account&quot; custom property (falling back to SettingsManager.get_active_email_config_name() when absent) and pre-select the matching combo item; it shall also load the sender display name from the &quot;Email Sender Name&quot; custom property and pre-fill the Sender Name field." Section_number="6.4.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="127.0" Object_Heading="" Object_Text="The MainWindow.open_email_config() method shall retrieve the current project via logic.get_data() and pass it to EmailConfigDialog; when the dialog is accepted and a project is open, _mark_dirty() shall be called so the updated custom properties are persisted on the next file save." Section_number="6.4.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="128.0" Object_Heading="" Object_Text="EmailConfigDialog._get_current_config() shall return the selected account dict with both a &quot;sender_address&quot; key injected from the Sender Address field and a &quot;sender_name&quot; key injected from the Sender Name field (each injected only when non-empty) when the account combo contains at least one entry; it shall return None when the combo is hidden (no accounts configured); the hidden/visible check shall use QWidget.isHidden() rather than isVisible() to work correctly in test environments where the dialog top-level window is not shown." Section_number="6.4.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="129.0" Object_Heading="" Object_Text="The email_integration._get_sender_address() function shall return the sender address formatted as &quot;Display Name &lt;address&gt;&quot; (RFC 2822 name-addr, produced via email.utils.formataddr) when the resolved config dict contains a non-empty &quot;sender_name&quot; value; when &quot;sender_name&quot; is absent or an empty string the plain email address shall be returned unchanged." Section_number="6.4.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="130.0" Object_Heading="" Object_Text="The EmailConfigDialog &quot;Sender (Per-Project)&quot; group box shall contain, in order: a Sender Address QLineEdit (smtp-level From: address, e.g. &quot;alice@example.com&quot;), a &quot;From KeePass…&quot; button that auto-fills the Sender Address by performing an Active Directory lookup on the current KeePass entry username, and a Sender Name QLineEdit (display name for the From: header, e.g. &quot;Alice Smith&quot;)." Section_number="6.4.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="131.0" Object_Heading="" Object_Text="On accepting the EmailConfigDialog, the sender email address shall be written to the project sidecar JSON under the MPXJ enterprise custom property key &quot;Email Sender Address&quot; using the same java.util.HashMap mechanism as the other per-project keys (&quot;Email Active Account&quot;, &quot;Email Sender Name&quot;)." Section_number="6.4.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="132.0" Object_Heading="" Object_Text="When EmailConfigDialog is initialised with a project argument, it shall load the sender email address from the &quot;Email Sender Address&quot; enterprise custom property and pre-fill the Sender Address field; when the property is absent or empty the field shall remain blank." Section_number="6.4.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_Heading.0" Object_Heading="7 Jira Integration" Object_Text="" Section_number="7" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="133.0" Object_Heading="" Object_Text="Requirements for syncing project tasks with Jira issues via the Jira REST API, supporting multiple authentication methods (API Token for Jira Cloud, Password, Personal Access Token for Jira Server/Data Center) with KeePass credential management." Section_number="7.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_1_Heading.0" Object_Heading="7.1 Server Connection &amp; Authentication" Object_Text="" Section_number="7.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="134.0" Object_Heading="" Object_Text="The system shall connect to Jira servers (Cloud or Data Center/Server) using the jira Python library with REST API authentication." Section_number="7.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="135.0" Object_Heading="" Object_Text="The Jira integration shall support three authentication methods: API Token (Jira Cloud with username + token via basic_auth), Password (legacy basic auth with username + password), and Personal Access Token (Jira Server/Data Center with token-only via token_auth)." Section_number="7.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="136.0" Object_Heading="" Object_Text="The Jira integration shall store server configurations as a JSON array in QSettings under the jira/servers key, with each server dict containing name, url, auth_mode (manual or keepass), credential_type (token, password, or pat), username, token (for manual mode), and keepass_entry (for keepass mode)." Section_number="7.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="137.0" Object_Heading="" Object_Text="The Jira integration shall expose a test_connection(server: dict) function that returns a tuple (success: bool, error_message: str), creating a JIRA client, calling myself() for authentication verification, and recording the test result with timestamp in a module-level _last_connection_test variable." Section_number="7.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="138.0" Object_Heading="" Object_Text="The Jira integration shall expose a get_jira_client(server: dict) function that returns a tuple (JIRA instance | None, error_message: str) for use in synchronization operations." Section_number="7.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="139.0" Object_Heading="" Object_Text="The Jira integration shall select authentication method based on credential_type: for &quot;pat&quot; use JIRA(server=url, token_auth=credential), for &quot;token&quot; or &quot;password&quot; use JIRA(server=url, basic_auth=(username, credential))." Section_number="7.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="140.0" Object_Heading="" Object_Text="The Jira integration shall validate credentials based on auth type: for PAT mode credential must be present but username is optional, for API Token or Password mode both username and credential must be present." Section_number="7.1.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="141.0" Object_Heading="" Object_Text="The Jira integration shall strip leading and trailing whitespace from all retrieved credentials (username and credential) from both manual settings and KeePass entries to prevent HTTP header validation errors." Section_number="7.1.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_2_Heading.0" Object_Heading="7.2 Jira Servers Configuration Dialog" Object_Text="" Section_number="7.2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="142.0" Object_Heading="" Object_Text="The system shall provide a Jira Servers Configuration dialog accessible from the TASK ribbon panel Jira Sync Config button, displaying a list of configured servers with Add, Edit, Delete buttons and a server details form." Section_number="7.2.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="143.0" Object_Heading="" Object_Text="The Jira Server Edit dialog shall provide authentication mode selection (Manual or KeePass) with dynamic UI showing appropriate credential fields based on the selected mode." Section_number="7.2.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="144.0" Object_Heading="" Object_Text="The Jira Server Edit dialog shall provide a Credential Type dropdown with three options: &quot;API Token (Jira Cloud)&quot; (credential_type=token), &quot;Password&quot; (credential_type=password), and &quot;Personal Access Token (Server/Data Center)&quot; (credential_type=pat), visible in both Manual and KeePass authentication modes." Section_number="7.2.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="145.0" Object_Heading="" Object_Text="The Jira Server Edit dialog shall update the credential field label and placeholder text dynamically based on selected credential type: &quot;API Token:&quot; with placeholder &quot;API token (for Jira Cloud)&quot; for token mode, &quot;Password:&quot; with placeholder &quot;password&quot; for password mode, and &quot;Personal Access Token:&quot; with placeholder &quot;Personal Access Token (for Jira Server/Data Center)&quot; for PAT mode." Section_number="7.2.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="146.0" Object_Heading="" Object_Text="The Jira Server Edit dialog shall include a Test Connection button that validates form inputs, builds a temporary server configuration dict, calls jira_integration.test_connection(), and displays the result in a QMessageBox with success or error details." Section_number="7.2.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="147.0" Object_Heading="" Object_Text="The Test Connection button shall validate PAT mode requirements (credential present, username optional) separately from API Token/Password mode requirements (both username and credential present)." Section_number="7.2.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="148.0" Object_Heading="" Object_Text="The Jira Server Edit dialog shall support KeePass mode with three-state stack widget showing: not configured (with Configure KeePass button), locked (with Unlock KeePass button), and unlocked (with entry selector combo and New Entry button)." Section_number="7.2.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="149.0" Object_Heading="" Object_Text="The Jira Server Edit dialog shall save credential_type to server configuration for both Manual and KeePass authentication modes." Section_number="7.2.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="150.0" Object_Heading="" Object_Text="The Jira integration shall expose a get_config_summary() function that returns a dict with servers list containing name, url, auth_mode, credential_type for each server, and last_connection_test result, without exposing username, token, or keepass_entry." Section_number="7.2.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="151.0" Object_Heading="" Object_Text="When the --debug flag is active, test_connection shall print detailed debug messages showing: server configuration, authentication mode, credential retrieval status, JIRA client creation, authentication method used (basic_auth or token_auth), and full exception tracebacks on errors." Section_number="7.2.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_3_Heading.0" Object_Heading="7.3 Ribbon Panel &amp; Menu Integration" Object_Text="" Section_number="7.3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="152.0" Object_Heading="" Object_Text="The TASK ribbon panel shall include a Jira group with a Jira Sync Config button (always enabled) positioned after the Clipboard group and before the Resource Usage tab's hidden groups list." Section_number="7.3.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="153.0" Object_Heading="" Object_Text="The Jira Sync Config button shall use the confluence_settings icon and call ui.open_jira_config() when clicked." Section_number="7.3.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="154.0" Object_Heading="" Object_Text="The MainWindow (ui.py) shall expose an open_jira_config() method that opens the JiraSyncConfigDialog with the settings_manager instance." Section_number="7.3.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="155.0" Object_Heading="" Object_Text="The MainWindow (ui.py) shall expose an open_jira_settings() method that opens the JiraServersDialog with the settings_manager instance." Section_number="7.3.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="156.0" Object_Heading="" Object_Text="The Project menu shall include a Jira submenu containing two entries: &quot;Jira Sync Configuration...&quot; (calling open_jira_config) and &quot;Jira Servers...&quot; (calling open_jira_settings)." Section_number="7.3.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_4_Heading.0" Object_Heading="7.4 Jira Sync Config Dialog – Server &amp; Persistence" Object_Text="" Section_number="7.4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="157.0" Object_Heading="" Object_Text="The system shall provide a JiraSyncConfigDialog accessible from the Jira Sync Config ribbon button and the Project &gt; Jira &gt; Jira Sync Configuration menu, displaying a dropdown of configured Jira servers and an Add button." Section_number="7.4.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="158.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall populate the server dropdown from SettingsManager.get_jira_servers() and pre-select the previously saved sync server from SettingsManager.get_jira_sync_server()." Section_number="7.4.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="159.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog server dropdown shall be disabled when no Jira servers are configured and enabled when at least one server exists." Section_number="7.4.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="160.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog Add button shall open the JiraServersDialog and refresh the server dropdown when the dialog is closed." Section_number="7.4.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="161.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall save the selected server name to QSettings via SettingsManager.set_jira_sync_server() when the user clicks OK." Section_number="7.4.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="162.0" Object_Heading="" Object_Text="The SettingsManager shall provide get_jira_sync_server() returning a string (server name) stored in the jira/sync_server QSettings key, defaulting to empty string when not set." Section_number="7.4.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="163.0" Object_Heading="" Object_Text="The SettingsManager shall provide set_jira_sync_server(server_name: str) that persists the selected sync server name to QSettings and calls sync()." Section_number="7.4.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="164.0" Object_Heading="" Object_Text="Sensitive information (API tokens, passwords, Personal Access Tokens, KeePass entries) shall never be written to log files, debug dumps, QSettings display, or error messages." Section_number="7.4.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="165.0" Object_Heading="" Object_Text="The Jira integration shall handle HTTP 403 &quot;Basic Authentication has been disabled&quot; errors from Jira servers by using token_auth when credential_type is set to &quot;pat&quot;." Section_number="7.4.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="166.0" Object_Heading="" Object_Text="The SettingsManager shall provide get_jira_servers() returning list[dict], set_jira_servers(servers: list[dict]), and get_jira_credentials(server: dict) returning tuple[str, str] for username and credential." Section_number="7.4.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="167.0" Object_Heading="" Object_Text="The SettingsManager.get_jira_credentials() shall strip leading and trailing whitespace from both username and credential fields retrieved from manual settings or KeePass entries." Section_number="7.4.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_5_Heading.0" Object_Heading="7.5 Jira Sync Config Dialog – JQL Filter" Object_Text="" Section_number="7.5" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="168.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall include a JQL Filter text input field for specifying a Jira Query Language filter string (e.g., &quot;project = MYPROJECT AND status = 'In Progress'&quot;) to determine which issues are synced." Section_number="7.5.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="169.0" Object_Heading="" Object_Text="The JQL Filter field shall display a comprehensive tooltip with JQL syntax examples covering project filters, status filters, assignee filters, date range filters, priority filters, labels, components, and combined filters." Section_number="7.5.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="170.0" Object_Heading="" Object_Text="The JQL Filter field shall include a Test Filter button that validates the server selection and filter text, connects to the selected Jira server, executes jira.search_issues(filter_text, maxResults=50), and displays the number of matching issues and a summary of the first 10 in a QMessageBox." Section_number="7.5.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="171.0" Object_Heading="" Object_Text="The Test Filter button shall validate that a server is selected and a filter is specified before attempting to connect." Section_number="7.5.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="172.0" Object_Heading="" Object_Text="The Test Filter button shall display a wait cursor during the connection and filter execution, restoring the normal cursor when complete or on error." Section_number="7.5.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="173.0" Object_Heading="" Object_Text="The JQL Filter field, filter type, and field-selection state shall be stored per-project in enterprise custom properties (sidecar .custom-props.json file) inside a single JSON container value under the key &quot;jira2project&quot;, making all Jira sync settings portable with the project file." Section_number="7.5.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="174.0" Object_Heading="" Object_Text="The JQL Filter field shall be disabled when no project is open, with a hint message informing the user that filters are project-specific." Section_number="7.5.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="175.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall load the saved filter from project custom properties when initialized with a project parameter, displaying it in the filter text field." Section_number="7.5.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="176.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall save the filter text to project custom properties when the user clicks OK and a project is open, preserving existing custom properties." Section_number="7.5.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="177.0" Object_Heading="" Object_Text="The MainWindow.open_jira_config() method shall pass the current project instance to the JiraSyncConfigDialog and call _mark_dirty() when the dialog is accepted with a project open, triggering custom properties save." Section_number="7.5.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="178.0" Object_Heading="" Object_Text="The Jira integration shall expose a record_filter_test(server_name: str, filter_text: str, issue_count: int, error: str) function that records filter test results with timestamp, success status, and error message in a module-level _last_filter_test variable for diagnostic purposes." Section_number="7.5.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="179.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog._test_filter() method shall call record_filter_test() after each filter test attempt (successful or failed), recording the server name, filter text, issue count, and error message." Section_number="7.5.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="180.0" Object_Heading="" Object_Text="The get_config_summary() function shall include the last_filter_test result when available, containing server_name, filter, issue_count, timestamp, success, and error fields." Section_number="7.5.13" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_6_Heading.0" Object_Heading="7.6 Jira Sync Config Dialog – Saved Filter Support" Object_Text="" Section_number="7.6" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="181.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall include a Filter Type selector with two radio buttons: &quot;JQL&quot; (raw JQL string) and &quot;Saved Filter (ID or URL)&quot; (a Jira saved filter referenced by numeric ID or full filter URL)." Section_number="7.6.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="182.0" Object_Heading="" Object_Text="When &quot;JQL&quot; is selected as the filter type, the filter input field shall display a placeholder and tooltip with JQL syntax examples; when &quot;Saved Filter (ID or URL)&quot; is selected it shall display a placeholder and tooltip describing the accepted formats (numeric ID or full ?filter= URL)." Section_number="7.6.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="183.0" Object_Heading="" Object_Text="The filter type selection shall be persisted per-project inside the &quot;jira2project&quot; JSON container as the &quot;filter_type&quot; key (value: &quot;jql&quot; or &quot;filter&quot;), stored together with the filter text in the same container." Section_number="7.6.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="184.0" Object_Heading="" Object_Text="When loading filter settings from project custom properties, the JiraSyncConfigDialog shall JSON-parse the &quot;jira2project&quot; container, read the &quot;filter_type&quot; key from the parsed dict, and pre-select the corresponding radio button, defaulting to &quot;jql&quot; when the key is absent or contains an unrecognised value; for backward compatibility it shall also accept the legacy flat key &quot;JIRA Sync Filter Type&quot; when the container is absent." Section_number="7.6.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="185.0" Object_Heading="" Object_Text="When the filter input is cleared and saved, the &quot;jira2project&quot; container shall be written without the &quot;filter&quot; and &quot;filter_type&quot; keys (other container fields such as field selections are preserved)." Section_number="7.6.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="186.0" Object_Heading="" Object_Text="Both Filter Type radio buttons shall be disabled when no project is open, matching the disabled state of the filter input field." Section_number="7.6.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="187.0" Object_Heading="" Object_Text="The Jira integration shall expose a _extract_filter_id(value: str) helper that extracts a numeric Jira filter ID from a full ?filter= URL, a filter=ID query string fragment, or a plain numeric string, returning an empty string when no ID can be found." Section_number="7.6.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="188.0" Object_Heading="" Object_Text="The Jira integration shall expose a resolve_filter_to_jql(jira, filter_value: str, filter_type: str) function that, for filter_type=&quot;jql&quot;, returns the value unchanged; for filter_type=&quot;filter&quot;, calls jira.filter(id).jql to retrieve the JQL of a saved filter and returns it together with an empty error string, or returns (&quot;&quot;, error_message) on failure." Section_number="7.6.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="189.0" Object_Heading="" Object_Text="The Test Filter button shall, when the selected server uses KeePass authentication and the KeePass database is locked, present a QMessageBox.question asking the user whether to unlock KeePass now, and abort the test if the user declines." Section_number="7.6.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="190.0" Object_Heading="" Object_Text="If the user accepts the KeePass unlock prompt in Test Filter, the system shall attempt auto_unlock_keepass() first; if that fails, it shall prompt for the master password via QInputDialog, show a warning on failure, and abort the test." Section_number="7.6.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="191.0" Object_Heading="" Object_Text="When filter_type is &quot;filter&quot;, Test Filter shall call resolve_filter_to_jql() to obtain the JQL before executing jira.search_issues(); if resolution fails it shall display a &quot;Filter Resolution Failed&quot; error dialog and record the error via record_filter_test() without executing the search." Section_number="7.6.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="192.0" Object_Heading="" Object_Text="When filter_type is &quot;filter&quot; and the test succeeds, the Test Filter result dialog shall include the resolved JQL string alongside the issue count summary." Section_number="7.6.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="7_7_Heading.0" Object_Heading="7.7 Jira Sync Config Dialog – Field Mapping &amp; Layout" Object_Text="" Section_number="7.7" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="193.0" Object_Heading="" Object_Text="The file_handler module shall transparently expand JSON-object string values in the sidecar .custom-props.json file into nested dicts on save (any value whose string representation starts with &quot;{&quot;) and re-serialize nested dicts back to JSON strings on load, so that the &quot;jira2project&quot; container is stored as a readable nested object in the sidecar file while the MPXJ HashMap always receives a plain JSON string." Section_number="7.7.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="194.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall implement cross-field dependency rules for the Jira→Project field-selection tab via the module-level `_JIRA2PROJECT_FIELD_DEPENDENCIES` mapping: the dependent checkboxes `jira_status_percent`, `jira_resolution_date`, `jira_assignee_display_name`, `jira_reporter_display_name`, `jira_fix_version_description`, `jira_fix_version_released`, `jira_fix_version_start_date`, `jira_fix_version_release_date`, `jira_time_spent_seconds`, and `jira_worklog_entries` shall each be automatically disabled and unchecked when their respective controller checkbox (`jira_status`, `jira_resolution`, `jira_assignee`, `jira_reporter`, `jira_fix_versions`, or `jira_time_spent`) is unchecked; each dependent checkbox shall be re-enabled when its controller is re-checked." Section_number="7.7.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="195.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall constrain its maximum height to QApplication.desktop().availableGeometry().height() minus a 40 px chrome buffer so that the OK/Cancel button row is always fully visible on screen regardless of screen resolution or taskbar height." Section_number="7.7.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="196.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall wrap the content of each tab (Jira → Project and Project → Jira) in a QScrollArea with setWidgetResizable(True) and QFrame.NoFrame, so that all tab content is reachable by scrolling within the tab without expanding the dialog beyond its maximum height." Section_number="7.7.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="8_Heading.0" Object_Heading="8 Jira → Project Sync" Object_Text="" Section_number="8" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="197.0" Object_Heading="" Object_Text="Requirements for the runtime Jira-to-Project synchronisation engine (integrations/jira_sync.py) that reads Jira issues via the configured filter and creates or updates MPXJ tasks in the open project file. The configuration (server, filter, field selection) is managed by JiraSyncConfigDialog and stored in the jira2project custom-properties container; these requirements cover only the sync execution logic." Section_number="8.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="8_1_Heading.0" Object_Heading="8.1 Jira → Project Sync Engine" Object_Text="" Section_number="8.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="198.0" Object_Heading="" Object_Text="All values received from Jira and written to a task during sync shall be persisted in the .custom-props.json sidecar file (the task JSON prop file)." Section_number="8.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="199.0" Object_Heading="" Object_Text="The synced values for a task shall be stored as a nested JSON object under the key &quot;jira&quot; inside the per-task custom property entry in the sidecar; the Jira issue key used as the lookup identifier shall be stored under the sub-key &quot;jira_key&quot; within that object." Section_number="8.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="200.0" Object_Heading="" Object_Text="Only field values whose flag is enabled in the sync configuration (jira2project.fields.&lt;field_name&gt; == true) shall be written to the sidecar; essential fields (jira_key, jira_issue_type, jira_project_key) shall always be stored regardless of the field-selection checkboxes." Section_number="8.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="201.0" Object_Heading="" Object_Text="The sync configuration shall support the following 34 boolean field flags in the jira2project.fields sub-dict: jira_project_name, jira_description, jira_status, jira_status_percent, jira_resolution, jira_resolution_date, jira_security_level, jira_assignee, jira_assignee_display_name, jira_reporter, jira_reporter_display_name, jira_priority, jira_due_date, jira_created_date, jira_updated_date, jira_components, jira_fix_versions, jira_affects_versions, jira_fix_version_description, jira_fix_version_released, jira_fix_version_start_date, jira_fix_version_release_date, jira_labels, jira_environment, jira_votes, jira_comments, jira_time_spent, jira_remaining_estimate, jira_original_estimate, jira_time_spent_seconds, jira_worklog_entries, jira_parent_key, jira_epic_link, jira_parent_link, jira_subtask_parent, jira_issue_links." Section_number="8.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="202.0" Object_Heading="" Object_Text="All 34 field flags shall default to false when not explicitly saved in the configuration." Section_number="8.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="203.0" Object_Heading="" Object_Text="When the jira_status_percent flag is enabled, the Jira issue status name shall be mapped to a numeric &quot;% Complete&quot; value and applied to the MPXJ task." Section_number="8.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="204.0" Object_Heading="" Object_Text="Multi-value fields (jira_components, jira_fix_versions, jira_affects_versions, jira_labels) shall be stored as comma-separated strings in the sidecar." Section_number="8.1.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="205.0" Object_Heading="" Object_Text="For each Jira issue returned by the configured filter, the sync engine shall look up whether a matching task already exists in the project by comparing the issue key against the jira_key value stored in each task's sidecar entry." Section_number="8.1.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="206.0" Object_Heading="" Object_Text="The lookup shall be performed by building a dictionary mapping every jira_key value found in the sidecar data to its corresponding MPXJ task object at the start of each sync run." Section_number="8.1.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="207.0" Object_Heading="" Object_Text="A task shall be considered a match if its sidecar jira_key value equals the issue key of the Jira issue being processed; the comparison shall be exact (case-sensitive)." Section_number="8.1.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="208.0" Object_Heading="" Object_Text="If no matching task exists for a Jira issue, a new MPXJ task shall be created and the result shall be counted as &quot;created&quot;." Section_number="8.1.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="209.0" Object_Heading="" Object_Text="The new task name shall be set to the Jira issue summary." Section_number="8.1.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="210.0" Object_Heading="" Object_Text="The Jira issue key shall always be saved to the new task's sidecar property jira_key (essential field, written regardless of field flags)." Section_number="8.1.13" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="211.0" Object_Heading="" Object_Text="If the jira_assignee field flag is enabled and the Jira issue has an assignee, a resource assignment shall be created in MPXJ using the assignee display name; if the flag is disabled or the issue has no assignee, the task shall be created without any resource assignment." Section_number="8.1.14" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="212.0" Object_Heading="" Object_Text="All other enabled field values shall be written to the task sidecar on task creation." Section_number="8.1.15" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="213.0" Object_Heading="" Object_Text="If a matching task already exists, its properties shall be updated with the current values received from Jira and the result shall be counted as &quot;updated&quot;." Section_number="8.1.16" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="214.0" Object_Heading="" Object_Text="The task name shall be updated to the current Jira issue summary on every sync run (the task name always tracks the latest Jira ticket summary)." Section_number="8.1.17" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="215.0" Object_Heading="" Object_Text="All enabled field values shall be re-written to the task sidecar on update; values for disabled flags shall not be modified or removed." Section_number="8.1.18" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="216.0" Object_Heading="" Object_Text="The resource assignment shall be updated according to the jira_assignee flag in the same way as for new tasks: create or update the assignment when the flag is enabled, leave the current assignment unchanged when the flag is disabled." Section_number="8.1.19" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="217.0" Object_Heading="" Object_Text="When a Jira issue is of type Epic (detected via issue.fields.issuetype.name == &quot;Epic&quot;), it shall be created or updated as an MPXJ summary task with the Summary and Rollup properties set to 1 at the appropriate WBS outline level." Section_number="8.1.20" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="218.0" Object_Heading="" Object_Text="Sub-tickets that belong to an Epic (identified by fields.parent.key matching the Epic issue key on modern Jira, or customfield_10014 on older Jira instances) shall be placed as child tasks one WBS outline level below the Epic summary task, wired via MPXJ task.setParentTask()." Section_number="8.1.21" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="219.0" Object_Heading="" Object_Text="The task name for both Epic container tasks and their sub-tickets shall be set to the Jira issue summary without any prefix or abbreviation." Section_number="8.1.22" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="220.0" Object_Heading="" Object_Text="The issue_type_labels mapping (stored as a JSON dict in the jira2project configuration under &quot;issue_type_labels&quot;) shall be retained for future use but shall not influence the task name written to the project." Section_number="8.1.23" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="221.0" Object_Heading="" Object_Text="During sync the engine shall process Epics before their sub-tickets so that the parent summary task always exists before child tasks are appended to it." Section_number="8.1.24" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="222.0" Object_Heading="" Object_Text="If an Epic's summary task already exists in the project (matched via jira_key on the summary task), sub-tickets shall be looked up among the existing children of that summary task by jira_key before creating new child tasks." Section_number="8.1.25" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="223.0" Object_Heading="" Object_Text="The _normalize_jira_datetime(date_str) function shall convert a Jira ISO-8601 datetime string that contains a 'T' separator and a timezone offset (or 'Z') to a UTC ISO-8601 string with a 'Z' suffix; strings without a 'T' separator (date-only strings) shall be returned unchanged; empty or None inputs shall be returned unchanged." Section_number="8.1.26" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="224.0" Object_Heading="" Object_Text="When the jira_created_date, jira_updated_date, or jira_resolution_date field flags are enabled in the jira2project sync configuration, the sync engine shall call _normalize_jira_datetime() on the raw Jira field value before storing it in the task sidecar, so that all stored date-time values are in UTC ISO-8601 format with a 'Z' suffix." Section_number="8.1.27" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="8_2_Heading.0" Object_Heading="8.2 Ribbon Button &amp; UI Handler" Object_Text="" Section_number="8.2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="225.0" Object_Heading="" Object_Text="A &quot;Sync from Jira&quot; button shall be added to the TASK ribbon panel Jira group alongside the existing Jira Sync Config button; the button shall be enabled only when a project is open and disabled otherwise." Section_number="8.2.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="226.0" Object_Heading="" Object_Text="Before starting the sync, the button handler shall verify that a Jira server is configured and a filter is set for the open project (read from the jira2project custom properties); if not configured, it shall open JiraSyncConfigDialog automatically instead of proceeding to sync." Section_number="8.2.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="227.0" Object_Heading="" Object_Text="After the sync completes, a QMessageBox dialog shall display the result summary showing the number of tasks created, updated, and skipped, and the list of errors if any; a warning-type dialog shall be used when errors are present, an information-type dialog otherwise." Section_number="8.2.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="228.0" Object_Heading="" Object_Text="After the sync completes, all project views shall be refreshed and the project shall be marked as dirty (unsaved changes) so that the updated task data is persisted on the next file save." Section_number="8.2.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="229.0" Object_Heading="" Object_Text="The &quot;Sync from Jira&quot; ribbon button shall be a split-button with four dropdown actions: &quot;Sync now (normal)&quot;, &quot;Changed since last sync&quot;, &quot;Full resync&quot;, and &quot;Open Jira Config&quot;; the main click area shall trigger the normal sync." Section_number="8.2.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="230.0" Object_Heading="" Object_Text="When &quot;Changed since last sync&quot; is selected from the Sync from Jira dropdown, the sync engine shall be invoked with force_incremental=True, overriding any saved sync mode and fetching only Jira issues updated since the last successful sync timestamp." Section_number="8.2.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="231.0" Object_Heading="" Object_Text="When &quot;Full resync&quot; is selected from the Sync from Jira dropdown, the sync engine shall be invoked with force_full_resync=True, bypassing the last-sync timestamp and re-fetching all issues matching the configured filter regardless of any incremental mode setting." Section_number="8.2.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="8_3_Heading.0" Object_Heading="8.3 Sync Execution Details" Object_Text="" Section_number="8.3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="232.0" Object_Heading="" Object_Text="The run_sync function shall return a result dict with keys: &quot;created&quot; (int), &quot;updated&quot; (int), &quot;skipped&quot; (int), &quot;errors&quot; (list of str), and &quot;log&quot; (list of str debug messages)." Section_number="8.3.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="233.0" Object_Heading="" Object_Text="When is_debug() is True, the sync function shall emit a structured [DEBUG] log line prefixed with &quot;[DEBUG] jira2project_sync.run:&quot; for each processed Jira issue." Section_number="8.3.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="234.0" Object_Heading="" Object_Text="For task creation the debug log line shall include the action token [CREATE], the Jira issue key, and the issue summary." Section_number="8.3.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="235.0" Object_Heading="" Object_Text="For task update the debug log line shall include the action token [UPDATE], the Jira issue key, and the issue summary." Section_number="8.3.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="236.0" Object_Heading="" Object_Text="The sync module shall maintain a module-level _last_result variable storing the result dict of the most recent sync run, accessible via a public get_last_result() function." Section_number="8.3.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="237.0" Object_Heading="" Object_Text="Before calling get_jira_client() to initiate a &quot;Sync from Jira&quot; operation, the button handler shall check whether the selected server uses KeePass authentication and the KeePass database is currently locked; if so, it shall present a QMessageBox.question asking the user to unlock now, attempt auto_unlock_keepass() first, fall back to a QInputDialog password prompt, and abort the sync if the database cannot be unlocked or the user declines." Section_number="8.3.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="238.0" Object_Heading="" Object_Text="The sync engine shall fetch all Jira issues matching the configured filter by paginating through the Jira REST API in pages of 100 issues until no further results are returned, so that result sets larger than any single page limit are fully imported." Section_number="8.3.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="239.0" Object_Heading="" Object_Text="The sync engine shall request only the specific Jira fields required for sync (summary, issuetype, status, parent, customfield_10014, duedate, assignee, description, priority) rather than all fields, in order to reduce response payload size and prevent HTTP 504 Gateway Timeout errors on large result sets." Section_number="8.3.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="240.0" Object_Heading="" Object_Text="When advanced.relink.behavior is set to 'messagebox' in the jira2project configuration, run_sync shall invoke relink_callback(issue_key, stored_task_uid, incoming_task_uid) if a non-None callback was supplied and shall use the returned string ('skip' or 'relink') to decide the action; if no callback is supplied, the behavior shall default to 'skip'." Section_number="8.3.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="241.0" Object_Heading="" Object_Text="When advanced.conflict.policy is set to 'messagebox' in the jira2project configuration, run_sync shall invoke conflict_callback(issue_key, task_name) if a non-None callback was supplied and shall use the returned string ('prefer_jira', 'prefer_local', or 'skip') to resolve the conflict; if no callback is supplied, the behavior shall default to 'skip'." Section_number="8.3.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="242.0" Object_Heading="" Object_Text="When advanced.orphan.behavior is set to 'messagebox' in the jira2project configuration, run_sync shall invoke orphan_callback(jira_key, task_name) if a non-None callback was supplied and shall use the returned string ('keep', 'unlink', 'delete', or 'close') to handle the orphaned task; if no callback is supplied, the behavior shall default to 'keep'." Section_number="8.3.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="8_4_Heading.0" Object_Heading="8.4 Task Information Dialog – Jira Tab" Object_Text="" Section_number="8.4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="243.0" Object_Heading="" Object_Text="The Task Information dialog shall include a read-only &quot;Jira&quot; tab that displays the Jira key and status linked to the task via the sidecar .custom-props.json file; when the task has no Jira linkage the tab shall show an explanatory message." Section_number="8.4.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="244.0" Object_Heading="" Object_Text="The Jira tab shall construct a clickable browse URL from the configured Jira server base URL and the task's linked Jira key (format: &lt;base_url&gt;/browse/&lt;jira_key&gt;) and render it as a hyperlink that opens in the system browser." Section_number="8.4.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="245.0" Object_Heading="" Object_Text="The Task Information dialog shall receive the task's Jira sidecar entry as a task_jira_data parameter; each call site (Gantt view, Task Sheet view, Resource Usage Graph view) shall load the sidecar data and pass the matching entry for the task's UID when opening the dialog." Section_number="8.4.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9_Heading.0" Object_Heading="9 Project → Jira Export Configuration" Object_Text="" Section_number="9" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="246.0" Object_Heading="" Object_Text="Requirements for configuring the export of project tasks outbound to Jira issues via the JiraSyncConfigDialog &quot;Project → Jira&quot; tab, including tab structure, field and type mapping tables, per-project persistence, and pre-save validation." Section_number="9.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9_1_Heading.0" Object_Heading="9.1 Project → Jira Configuration Tab" Object_Text="" Section_number="9.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="247.0" Object_Heading="" Object_Text="The JiraSyncConfigDialog shall include a &quot;Project → Jira&quot; tab providing configuration for exporting project tasks outbound to Jira." Section_number="9.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="248.0" Object_Heading="" Object_Text="The Project → Jira tab shall include an Export Scope selector with two options: &quot;Selected Tasks&quot; (export only currently selected tasks in the Gantt view) and &quot;Full Project&quot; (export all tasks in the open project)." Section_number="9.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="249.0" Object_Heading="" Object_Text="The Project → Jira tab shall include a Create/Update Mode selector with three options: &quot;Create Only&quot; (create new Jira issues for unmatched tasks), &quot;Update Only&quot; (update existing matched Jira issues), and &quot;Create and Update&quot; (perform both create and update operations)." Section_number="9.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="250.0" Object_Heading="" Object_Text="The Project → Jira tab shall include a Conflict Policy selector with at least two options: &quot;Manual Review&quot; (pause on conflicts and prompt the user) and &quot;Prefer Jira&quot; (resolve conflicts automatically in favour of Jira data)." Section_number="9.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="251.0" Object_Heading="" Object_Text="The Project → Jira tab shall include a Dry Run checkbox; when checked the export operation shall be simulated without making any changes to the Jira server, allowing the user to preview the actions that would be taken." Section_number="9.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="252.0" Object_Heading="" Object_Text="The Project → Jira tab shall include a Field Map table in which each row maps a project field name to a target Jira field name; the table shall support Add, Edit, and Delete row operations." Section_number="9.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="253.0" Object_Heading="" Object_Text="The Project → Jira tab shall include an Issue Type Map table mapping project task type names to Jira issue type names; the table shall support Add, Edit, and Delete row operations." Section_number="9.1.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="254.0" Object_Heading="" Object_Text="The Project → Jira tab shall include a Transition Map table mapping project task status values to Jira transition IDs or transition names; the table shall support Add, Edit, and Delete row operations." Section_number="9.1.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="255.0" Object_Heading="" Object_Text="On accepting the JiraSyncConfigDialog, the Project → Jira export settings (export_scope, create_update_mode, conflict_policy, dry_run, fields, issue_type_map, transition_map) shall be persisted per-project as a JSON container value under the key &quot;project2jira&quot; in the enterprise custom properties sidecar, using the same HashMap mechanism as the &quot;jira2project&quot; container." Section_number="9.1.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="256.0" Object_Heading="" Object_Text="The &quot;Project → Jira&quot; tab in JiraSyncConfigDialog shall display the Unicode right-arrow character (U+2192) in the tab label, rendering as &quot;Project → Jira&quot; rather than the ASCII sequence &quot;Project -&gt; Jira&quot;." Section_number="9.1.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="257.0" Object_Heading="" Object_Text="The Export Scope, Create/Update Mode, Conflict Policy, and Unlinked Tasks selectors in the Project → Jira tab shall be implemented as QComboBox drop-down widgets instead of radio button groups; the respective options shall remain &quot;Selected Tasks / Changed since last sync / Full project&quot;, &quot;Create only / Update only / Create + update&quot;, &quot;Prefer Jira / Prefer Project / Manual review&quot;, and &quot;Create new issue / Skip / Prompt&quot;." Section_number="9.1.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="258.0" Object_Heading="" Object_Text="The Export Scope selector shall default to &quot;Changed since last sync&quot; when no previously saved value is present; the Jira field mapping edit widgets for each export field row, the hierarchy issue-type fields (Epic, Story, Sub-task), and the dependency link-type field shall each be implemented as editable QComboBox widgets pre-populated with standard Jira field name suggestions so that users can either select a suggestion or type a custom value." Section_number="9.1.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9_2_Heading.0" Object_Heading="9.2 Project → Jira Export Validation" Object_Text="" Section_number="9.2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="259.0" Object_Heading="" Object_Text="Before saving Project → Jira settings, the JiraSyncConfigDialog shall validate that at least one export field is enabled and that every enabled field has a non-empty Jira field name mapping; it shall display an error and refuse to close when this validation fails." Section_number="9.2.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="260.0" Object_Heading="" Object_Text="Before saving Project → Jira settings, the JiraSyncConfigDialog shall validate that at least one issue type mapping entry is present; it shall display an error and refuse to close when the Issue Type Map table is empty." Section_number="9.2.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="261.0" Object_Heading="" Object_Text="For create-capable export modes (create-only or create-and-update), the JiraSyncConfigDialog shall validate that at least one enabled field maps to the Jira field name &quot;project&quot; (case-insensitive); if the required mapping is absent, it shall display an error message listing the missing required field(s) and refuse to save." Section_number="9.2.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="262.0" Object_Heading="" Object_Text="Before saving Project → Jira settings, the JiraSyncConfigDialog shall validate every row in the Transition Map table to ensure that the Jira transition ID or name cell is non-empty; it shall display an error and refuse to close for any row that lacks a transition target." Section_number="9.2.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="263.0" Object_Heading="" Object_Text="When a Jira server is selected and accessible, the JiraSyncConfigDialog shall perform a best-effort server capability check for issue types by calling jira_client.issue_types(); it shall display an error listing any mapped issue type names not found on the server and refuse to save when unknown types are detected." Section_number="9.2.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="264.0" Object_Heading="" Object_Text="When a Jira server is selected and accessible and a non-empty Transition Map is configured, the JiraSyncConfigDialog shall perform a best-effort transition capability check: for each mapped Jira issue type it shall retrieve available transitions from a sample issue via jira_client.transitions() and reject any mapped transition ID or name not found among the available transitions, displaying an error and refusing to save." Section_number="9.2.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9_3_Heading.0" Object_Heading="9.3 Project → Jira Push Engine" Object_Text="" Section_number="9.3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="265.0" Object_Heading="" Object_Text="Requirements for the runtime Project-to-Jira push execution engine (integrations/jira_sync.py — run_push_to_jira). The configuration (export_scope, create_update_mode, conflict_policy, dry_run, fields, issue_type_map, transition_map) is read from the project2jira custom-properties container; these requirements cover only the push execution logic." Section_number="9.3" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9_3_1_Heading.0" Object_Heading="9.3.1 Push Execution" Object_Text="" Section_number="9.3.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="266.0" Object_Heading="" Object_Text="The system shall expose a run_push_to_jira(project, server, jira_client, sidecar_path, included_task_uids=None) function that returns a result dict with keys: created (int), updated (int), transitioned (int), skipped (int), errors (list[str]), log (list[str]), preview_actions (list[dict]), and dry_run (bool)." Section_number="9.3.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="267.0" Object_Heading="" Object_Text="When dry_run is True in the project2jira config, the push engine shall collect a list of preview_actions dicts without calling any write API on the Jira client; each entry shall include task_uid, task_name, jira_key (&quot;NEW&quot; for unlinked tasks), action (&quot;create&quot; or &quot;update&quot;), issue_type, changed_fields, and details." Section_number="9.3.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="268.0" Object_Heading="" Object_Text="For each eligible task that has no existing Jira link, the push engine shall apply the unlinked_task_behavior policy: &quot;skip&quot; increments the skipped counter and logs a [SKIP] entry; &quot;create&quot; (or &quot;prompt&quot; treated as create) proceeds to create a new Jira issue." Section_number="9.3.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="269.0" Object_Heading="" Object_Text="When an unlinked task is eligible for creation, the push engine shall call jira_client.create_issue(fields=…), record the new key and id in both task_jira and task_p2j sidecar sections, increment the created counter, and append a [CREATE] log entry." Section_number="9.3.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="270.0" Object_Heading="" Object_Text="When a task is linked to an existing Jira issue (jira_key present in task_jira or task_p2j sidecar), the push engine shall call jira_client.issue(key).update(fields=…) with the current field payload, increment the updated counter, and append an [UPDATE] log entry." Section_number="9.3.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="271.0" Object_Heading="" Object_Text="After a create or update action, if the task's status string (derived from percentage complete) matches a key in the transition_map, the push engine shall resolve the transition ID via jira_client.transitions(key) and call jira_client.transition_issue(key, transition_id), incrementing the transitioned counter and appending a [TRANSITION] log entry." Section_number="9.3.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="272.0" Object_Heading="" Object_Text="When conflict_policy is not &quot;prefer_project&quot; and the task has an existing Jira link, the push engine shall call jira_client.issue(key, fields=&quot;updated,summary&quot;) and compare remote_updated against task_p2j[uid].last_pushed_at; when remote_updated is newer, the conflict policy shall be applied: &quot;prefer_jira&quot; skips the update; &quot;manual_review&quot; skips and appends an error message." Section_number="9.3.1.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="273.0" Object_Heading="" Object_Text="When hierarchy_export.enabled is True and a task's parent task has an existing Jira key, the push engine shall call jira_client.issue(child_key).update(fields={&quot;parent&quot;: {&quot;key&quot;: parent_key}}) to set the parent link in Jira." Section_number="9.3.1.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="274.0" Object_Heading="" Object_Text="When the included_task_uids parameter is not None, the push engine shall restrict processing to only tasks whose unique-ID string is present in the set; all other eligible tasks shall be silently excluded." Section_number="9.3.1.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="275.0" Object_Heading="" Object_Text="The push engine shall expose a _with_retry(fn, max_retries, backoff_seconds) helper that calls fn(); on transient Jira errors (HTTP 429, 500, 502, 503, timeout, connection errors) it shall retry up to max_retries times with exponential backoff; non-transient exceptions shall propagate immediately on the first attempt." Section_number="9.3.1.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="276.0" Object_Heading="" Object_Text="After all tasks are processed, the push engine shall update the sidecar with task_jira, task_p2j, and jira_push_meta sections (last_run_at, last_result summary, last_successful_push when no errors) and write the sidecar to disk unless dry_run is True." Section_number="9.3.1.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="277.0" Object_Heading="" Object_Text="When auditability.enabled is True and dry_run is False, the push engine shall append an audit session entry to jira_push_meta.audit_sessions containing run_at, created, updated, transitioned, skipped, failed, reasons (up to 20 errors), and details (up to 100 per-task results); the audit_sessions list shall be capped at 20 entries." Section_number="9.3.1.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="278.0" Object_Heading="" Object_Text="The push module shall maintain a module-level _last_push_result variable storing the result dict of the most recent run_push_to_jira() call, accessible via a public get_last_push_result() function that returns None when no push has been executed in the current session." Section_number="9.3.1.13" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9_4_Heading.0" Object_Heading="9.4 Sync to Jira Ribbon Button and UI Handler" Object_Text="" Section_number="9.4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="279.0" Object_Heading="" Object_Text="The TASK ribbon panel Jira group shall include a &quot;Sync to Jira&quot; button alongside the existing &quot;Sync from Jira&quot; button; the button shall be enabled only when a project is open." Section_number="9.4.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="280.0" Object_Heading="" Object_Text="The MainWindow.run_jira_push() handler shall read the project2jira config from the project custom properties; if dry_run is True it shall first execute run_push_to_jira() in dry-run mode to obtain preview_actions, open the JiraPushPreviewDialog for the user to review and filter tasks, then re-execute run_push_to_jira() with the user-selected included_task_uids with dry_run temporarily forced to False; if dry_run is False it shall execute run_push_to_jira() directly." Section_number="9.4.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="281.0" Object_Heading="" Object_Text="The &quot;Sync to Jira&quot; ribbon button shall be a split-button; selecting &quot;Dry-run preview&quot; from the dropdown shall invoke the push handler with dry_run forced to True regardless of the saved project2jira configuration, allowing the user to preview push actions without changing the dialog settings." Section_number="9.4.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="9_5_Heading.0" Object_Heading="9.5 Jira Push Preview Dialog" Object_Text="" Section_number="9.5" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="282.0" Object_Heading="" Object_Text="The system shall provide a JiraPushPreviewDialog that displays the list of preview_actions returned by a dry-run push as a color-coded table: green for create actions, blue for update, amber for transition, and red for skip; each row shall include a checkbox allowing the user to deselect individual tasks from the actual push." Section_number="9.5.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="283.0" Object_Heading="" Object_Text="The JiraPushPreviewDialog shall expose a get_included_task_uids() method that returns a set of task UID strings for all rows whose Include checkbox is checked." Section_number="9.5.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_Heading.0" Object_Heading="10 Version Control Integration" Object_Text="" Section_number="10" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="284.0" Object_Heading="" Object_Text="Requirements for Git and SVN version control integration: repository detection, credential management via KeePass, commit/log/branch/restore operations, auto-commit on save, conflict handling, and non-blocking background execution." Section_number="10.1" aRequirementObjectType="information" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_1_Heading.0" Object_Heading="10.1 Repository Detection and Initialisation" Object_Text="" Section_number="10.1" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="285.0" Object_Heading="" Object_Text="The system shall detect whether the open project file resides in a Git or SVN working copy by walking the directory tree upward from the project file directory, looking for a .git directory or file (Git) or a .svn directory (SVN)." Section_number="10.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="286.0" Object_Heading="" Object_Text="The detect_repo() function shall return a dict with keys type (&quot;git&quot; or &quot;svn&quot;), root (effective repository root path), and either branch (Git) or revision (SVN); it shall return an empty dict when no repository is detected." Section_number="10.1.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="287.0" Object_Heading="" Object_Text="Repository detection shall handle nested repositories by stopping at the first .git or .svn found when walking upward, so the effective root always refers to the innermost enclosing repository." Section_number="10.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="288.0" Object_Heading="" Object_Text="The module shall expose init(project_file_path) to run detection on project open and reset() to clear all state on project close; the auto-commit debounce timer, if active, shall be cancelled by reset()." Section_number="10.1.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="289.0" Object_Heading="" Object_Text="The VERSION CONTROL ribbon tab shall be hidden by default and made visible only when init() detects a repository for the open project; it shall be hidden again when the project is closed." Section_number="10.1.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="290.0" Object_Heading="" Object_Text="The Git-specific ribbon groups (branch management, pull) shall be visible only when the detected repository type is &quot;git&quot;; the SVN-specific groups (update, cleanup) shall be visible only when the type is &quot;svn&quot;." Section_number="10.1.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_2_Heading.0" Object_Heading="10.2 Credential Management" Object_Text="" Section_number="10.2" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="291.0" Object_Heading="" Object_Text="VCS credentials shall be retrieved exclusively from the KeePass integration using a configurable entry name stored in QSettings under the vcs/keepass_entry key; credentials shall never be stored in QSettings, log files, or debug dumps." Section_number="10.2.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="292.0" Object_Heading="" Object_Text="For Git operations requiring authentication, the system shall inject credentials via the GIT_ASKPASS mechanism: a temporary .bat helper script shall be written to a system temp file, and GIT_ASKPASS_USERNAME and GIT_ASKPASS_PASSWORD environment variables shall be set in the subprocess environment so that credentials are never passed as command-line arguments." Section_number="10.2.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="293.0" Object_Heading="" Object_Text="The GIT_ASKPASS helper script shall be generated at runtime into a tempfile.mkstemp() path and cached for reuse; it shall be regenerated automatically if the cached file is deleted." Section_number="10.2.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="294.0" Object_Heading="" Object_Text="For SVN subprocesses, --non-interactive shall always be included in every svn command invocation. The --no-auth-cache flag and explicit --username/--password credential arguments shall be appended only when non-empty KeePass credentials are available; when no KeePass credentials are configured or available, --no-auth-cache shall be omitted so that SVN can authenticate using its local OS credential cache (e.g. Windows Credential Manager), enabling operations such as svn log to succeed without KeePass." Section_number="10.2.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="295.0" Object_Heading="" Object_Text="The GIT_TERMINAL_PROMPT environment variable shall be set to &quot;0&quot; for all git subprocess calls to prevent interactive credential prompts." Section_number="10.2.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="296.0" Object_Heading="" Object_Text="The _sanitise_output() function shall replace live credential values (username and password) in subprocess stdout/stderr with the tokens &lt;username&gt; and &lt;password&gt; before any output is logged or shown in the UI." Section_number="10.2.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="297.0" Object_Heading="" Object_Text="When KeePass is locked or the entry is not configured, the system shall present the user with options to unlock KeePass (via the standard KeePass unlock dialog), enter credentials manually for the current operation only, or skip the operation; plaintext credentials provided manually shall never be persisted." Section_number="10.2.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_3_Heading.0" Object_Heading="10.3 VCS Configuration Dialog" Object_Text="" Section_number="10.3" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="298.0" Object_Heading="" Object_Text="The VERSION CONTROL ribbon Setup group shall contain a VCS Config button (always enabled) that opens the VcsConfigDialog." Section_number="10.3.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="299.0" Object_Heading="" Object_Text="The VcsConfigDialog shall include a KeePass entry selector with a three-state QStackedWidget showing: not configured (with a Configure KeePass button), locked (with an Unlock KeePass button), and unlocked (with an entry selector combo)." Section_number="10.3.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="300.0" Object_Heading="" Object_Text="The VcsConfigDialog shall include controls for auto-commit configuration: an enable/disable checkbox, a commit message template QLineEdit (default &quot;Auto-commit: {project_name} saved at {timestamp}&quot;), and a scope selector (project file only vs. all tracked changes)." Section_number="10.3.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="301.0" Object_Heading="" Object_Text="The VcsConfigDialog shall include optional path override fields for git.exe and svn.exe, each with a Browse button; when left empty the system uses the bundled executables or falls back to PATH." Section_number="10.3.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="302.0" Object_Heading="" Object_Text="All VCS settings shall be persisted via the SettingsManager under the vcs/ QSettings prefix: vcs/keepass_entry, vcs/auto_commit_enabled, vcs/auto_commit_template, vcs/auto_commit_scope, vcs/git_path, vcs/svn_path." Section_number="10.3.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_4_Heading.0" Object_Heading="10.4 Commit Operation" Object_Text="" Section_number="10.4" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="303.0" Object_Heading="" Object_Text="The Commit button shall be enabled only when a project is open and a repository is detected; clicking it shall prompt the user for a commit message via QInputDialog." Section_number="10.4.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="304.0" Object_Heading="" Object_Text="Before executing a commit, the system shall perform pre-flight checks: for Git, detect any merge, rebase, or cherry-pick in progress by inspecting the .git directory; for SVN, detect working-copy locks by parsing svn status --xml; if a blocking condition is found, the commit shall be aborted with a user-facing explanation." Section_number="10.4.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="305.0" Object_Heading="" Object_Text="The commit scope shall respect the vcs/auto_commit_scope setting: &quot;project&quot; commits only the open project file; &quot;all&quot; commits all tracked changes in the working copy." Section_number="10.4.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="306.0" Object_Heading="" Object_Text="The &quot;Commit&quot; ribbon button shall be a split-button; selecting &quot;Commit all tracked changes&quot; from the dropdown shall commit all tracked changes in the working copy, overriding the vcs/auto_commit_scope setting for that single operation without modifying the saved configuration." Section_number="10.4.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_5_Heading.0" Object_Heading="10.5 Auto-Commit on Save" Object_Text="" Section_number="10.5" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="307.0" Object_Heading="" Object_Text="When vcs/auto_commit_enabled is True and a repository is detected, the system shall schedule a debounced auto-commit 3 seconds after each project save, so that rapid successive saves result in only one commit." Section_number="10.5.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="308.0" Object_Heading="" Object_Text="The auto-commit message shall be built from the vcs/auto_commit_template string by substituting {project_name} and {timestamp} placeholders." Section_number="10.5.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="309.0" Object_Heading="" Object_Text="The auto-commit shall be silently skipped if pre-flight checks detect a Git in-progress state or SVN lock, or if there are no staged changes to commit." Section_number="10.5.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_6_Heading.0" Object_Heading="10.6 Log, Diff, and Restore" Object_Text="" Section_number="10.6" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="310.0" Object_Heading="" Object_Text="The View Log button shall retrieve up to 100 history entries (configurable) from git log or svn log and display them in VcsLogDialog as a selectable list." Section_number="10.6.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="311.0" Object_Heading="" Object_Text="When a log entry is selected in VcsLogDialog, the system shall fetch and display the diff for that revision in a read-only monospace text panel below the list." Section_number="10.6.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="312.0" Object_Heading="" Object_Text="The VcsLogDialog shall include a Restore This Revision button that, after confirming with the user, calls restore_revision() for the selected entry." Section_number="10.6.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="313.0" Object_Heading="" Object_Text="Before any restore operation, the system shall create a safety snapshot of the current project file by copying it to a timestamped file named &lt;basename&gt;.vcs-snapshot.&lt;ISO-timestamp&gt;.&lt;ext&gt; in the same directory." Section_number="10.6.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="314.0" Object_Heading="" Object_Text="The restore operation shall support two modes: file-only (restores only the project file to its state at the selected revision) and full working copy (performs git checkout or svn revert to the selected revision across all files)." Section_number="10.6.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_7_Heading.0" Object_Heading="10.7 Branch Management (Git)" Object_Text="" Section_number="10.7" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="315.0" Object_Heading="" Object_Text="The Branch Management button shall be visible and enabled only when the detected repository type is &quot;git&quot;." Section_number="10.7.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="316.0" Object_Heading="" Object_Text="The VcsBranchDialog shall display the current list of local Git branches, allow the user to create a new branch, and allow the user to switch to an existing branch." Section_number="10.7.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_8_Heading.0" Object_Heading="10.8 Pull / Update" Object_Text="" Section_number="10.8" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="317.0" Object_Heading="" Object_Text="The Pull button (Git) shall run git pull in a background worker; the Update button (SVN) shall run svn update with an optional target revision." Section_number="10.8.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="318.0" Object_Heading="" Object_Text="After a pull or update operation completes, the system shall call get_conflicts() to scan for conflict markers; if conflicts are detected, VcsConflictDialog shall be opened listing the conflicting files with options to revert selected files or dismiss." Section_number="10.8.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="319.0" Object_Heading="" Object_Text="The &quot;Pull&quot; ribbon button (Git) shall be a split-button with three dropdown actions: &quot;Pull (merge)&quot; runs git pull with the default merge strategy, &quot;Pull (rebase)&quot; runs git pull --rebase, and &quot;Fetch only&quot; runs git fetch --all without merging." Section_number="10.8.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="320.0" Object_Heading="" Object_Text="The VCS integration module shall expose a git_fetch() function that executes git fetch --all; VcsWorker shall route the operation code &quot;fetch&quot; to git_fetch() so the fetch runs in a background thread." Section_number="10.8.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_9_Heading.0" Object_Heading="10.9 Non-Blocking Execution" Object_Text="" Section_number="10.9" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="321.0" Object_Heading="" Object_Text="All VCS subprocess operations (commit, pull, SVN update, SVN cleanup, diff, restore) shall be executed in a VcsWorker(QThread) background thread so the UI remains responsive during long-running network or disk operations." Section_number="10.9.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="322.0" Object_Heading="" Object_Text="VcsWorker shall emit a finished(bool, str) signal when the operation completes, carrying success status and sanitised output text." Section_number="10.9.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="323.0" Object_Heading="" Object_Text="All subprocess calls shall enforce a configurable timeout (default 30 s for standard operations); a timed-out call shall return returncode -1 with the message &quot;Command timed out.&quot;" Section_number="10.9.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="10_10_Heading.0" Object_Heading="10.10 SVN File Registration" Object_Text="" Section_number="10.10" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="324.0" Object_Heading="" Object_Text="The VERSION CONTROL ribbon Setup group shall display a 'Register with VCS' button (initially hidden) that becomes visible and enabled only when the detected repository type is 'svn' and the svn_is_unversioned() function returns True for the currently open project file; the button shall be hidden when no SVN repository is configured or the project file is already tracked by SVN." Section_number="10.10.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="325.0" Object_Heading="" Object_Text="The svn_is_unversioned(file_path) function shall run 'svn status -- &lt;file_path&gt;' as a subprocess and return True if the output contains a line whose first non-whitespace character is '?'; it shall return False if the output is empty (file is already tracked) or if the SVN executable is not found or no SVN repository is configured." Section_number="10.10.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="326.0" Object_Heading="" Object_Text="The svn_add(file_path) function shall run 'svn add -- &lt;file_path&gt;' as a subprocess, return a (bool, str) tuple where the bool indicates success (return code 0) and the str is the combined stdout/stderr output, and store operation='svn_add' in _last_status_result; VcsWorker shall route the operation code 'svn_add' to svn_add(**kwargs) so that the add runs in a background thread." Section_number="10.10.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="327.0" Object_Heading="" Object_Text="After a successful svn add operation, the system shall refresh the VCS ribbon state by calling _update_vcs_ribbon_state(), which shall hide the 'Register with VCS' button because svn_is_unversioned() will then return False for the newly registered file." Section_number="10.10.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="11_Heading.0" Object_Heading="11 Debug Dump" Object_Text="" Section_number="11" aRequirementObjectType="" a_EB_Variant="" a_EB_PO_Status="" a_ZF_PO_Status="" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="328.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a &quot;secondary_calendar&quot; block per resource in the resources list, containing the mapped calendar name, calendar UID, and a list of non-working exception entries (date, description) from the secondary calendar." Section_number="11.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="329.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include an ad_sync_result block with two sub-keys: &quot;sync&quot; (containing total, updated, skipped, errors from the last sync_resources() call, or null values when no sync has been run) and &quot;lookups&quot; (the full lookup history list from get_last_lookup_results())." Section_number="11.2" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="330.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a &quot;resource_calendars&quot; list within the &quot;ad_sync_result&quot; block, containing for each resource that has a personal calendar: resource name, calendar name, calendar UID, parent calendar name, and count of calendar exceptions." Section_number="11.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="331.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall split the AD lookup history into &quot;single_lookups&quot; (lookup_by_name / lookup_by_email / lookup_by_username), &quot;multi_result_searches&quot; (lookup_by_*_all with match count and matched user details), and &quot;ad_search_history&quot; (condensed chronological list)." Section_number="11.4" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="332.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump resources list shall include a &quot;calendar&quot; block per resource containing: calendar name, UID, parent calendar name, exception count, and the full list of calendar exceptions (from, to, name, working flag)." Section_number="11.5" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="333.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include an email_integration block containing the complete output of get_config_summary()." Section_number="11.6" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="334.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a jira_sync_config block containing the complete output of get_config_summary()." Section_number="11.7" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="335.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a jira_project_props block reading the &quot;jira2project&quot; custom property container from the project (JSON-parsing it if present), exposing filter_set (bool) and filter (string) keys." Section_number="11.8" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="336.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump jira_project_props block shall gracefully handle projects without the &quot;jira2project&quot; custom property by returning an empty dict." Section_number="11.9" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="337.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a jira_sync_result block obtained from get_last_result(), exposing created, updated, skipped, the first 20 errors, and the first 50 log entries; the block shall be empty when no sync has been run in the current session." Section_number="11.10" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="338.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a jira_push_result block obtained from get_last_push_result(), exposing created, updated, transitioned, skipped, the first 20 errors, and the first 50 log entries; the block shall be null when no push has been run in the current session." Section_number="11.11" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="339.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a jira_push_meta block reading the jira_push_meta section from the project sidecar, exposing last_run_at, last_successful_push, audit_session_count (length of audit_sessions list), and task_p2j_count (number of entries in the task_p2j section)." Section_number="11.12" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
        <OBJECTS ID.Status="340.0" Object_Heading="" Object_Text="When the --debug flag is active, the debug dump shall include a vcs_integration block containing the output of get_config_summary(): configured (bool), vcs_type, repo_root_set (bool), current_branch, keepass_entry_set (bool), auto_commit_enabled, auto_commit_scope, last_commit (without message text), and last_status; no credentials or commit message text shall appear in this block." Section_number="11.13" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
      </GROUP_OBJECTS>
    </Integrations>
  </Project_Offline>
</root>
