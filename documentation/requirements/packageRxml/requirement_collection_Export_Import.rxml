        <OBJECTS ID.Status="1.0" Object_Heading="" Object_Text="The system shall export the current project schedule as PlantUML @startgantt markup via the Export ribbon button." Section_number="1.1.1" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
