        <OBJECTS ID.Status="3.0" Object_Heading="" Object_Text="The Timeline View shall provide a separate PlantUML export of the pinned milestones and task bars." Section_number="1.1.3" aRequirementObjectType="functional requirement" a_EB_Variant="" a_EB_PO_Status="approved" a_ZF_PO_Status="aligned" a_RequestedInCR_PO="" a_EB4ZF_PO_Comment="" a_ZF4EB_PO_Comment="" RequirementParent=""/>
