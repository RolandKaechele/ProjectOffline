      <GROUP_FILEINFO>
        <FILEINFO Annotation="-" Creation_Date="1777892400" Creator="Project Offline" Description="Project Offline – Email Integration Requirements" Encoding="65001" Export_type="6.1" Internal_links_module="" Module="PO_14_EmailIntegration" Prefix="PO-EMAIL-" Scriptversion="1.0" Steps="0" Suffix="-" Version_number="1.0"/>
