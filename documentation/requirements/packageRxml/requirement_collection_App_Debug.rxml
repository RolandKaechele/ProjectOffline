      <GROUP_FILEINFO>
        <FILEINFO Annotation="-" Creation_Date="1777892400" Creator="Project Offline" Description="Project Offline – App Debug Dump Requirements" Encoding="65001" Export_type="6.1" Internal_links_module="" Module="PO_02_AppDebug" Prefix="PO-DBG-" Scriptversion="1.0" Steps="0" Suffix="-" Version_number="1.0"/>
