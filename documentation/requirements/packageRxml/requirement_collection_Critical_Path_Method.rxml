      <GROUP_FILEINFO>
        <FILEINFO Annotation="-" Creation_Date="1777892400" Creator="Project Offline" Description="Project Offline – Critical Path Method (CPM) Requirements" Encoding="65001" Export_type="6.1" Internal_links_module="" Module="PO_18_CriticalPathMethod" Prefix="PO-CPM-" Scriptversion="1.0" Steps="0" Suffix="-" Version_number="1.0"/>
